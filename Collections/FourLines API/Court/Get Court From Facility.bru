meta {
  name: Get Court From Facility
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v{{apiVersion}}/owner/{{ownerId}}/facility/{{facilityId}}/Court/:courtId
  body: none
  auth: inherit
}

params:path {
  courtId: 66cf2138-f695-43ae-8c57-87dad76d373a
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

script:post-response {
  test("Status 2xx",()=>expect(res.getStatus()).to.be.within(200,299));
}

settings {
  encodeUrl: true
  timeout: 0
}
