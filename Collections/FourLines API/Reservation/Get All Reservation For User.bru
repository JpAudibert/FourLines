meta {
  name: Get All Reservation For User
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v{{apiVersion}}/user/:userId/Reservation
  body: none
  auth: inherit
}

params:path {
  userId: e20819d6-6b28-4125-9608-6d1d1f75302d
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

script:post-response {
  test("Status 2xx",()=>expect(res.getStatus()).to.be.within(200,299));
}

settings {
  encodeUrl: true
  timeout: 0
}
