meta {
  name: Get All Reservations For Court
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v{{apiVersion}}/court/{{courtId}}/Reservation
  body: none
  auth: inherit
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

script:post-response {
  test("Status 2xx",()=>expect(res.getStatus()).to.be.within(200,299));
}

settings {
  encodeUrl: true
  timeout: 0
}
