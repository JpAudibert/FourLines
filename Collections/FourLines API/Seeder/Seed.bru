meta {
  name: Seed
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v{{apiVersion}}/Seeder
  body: none
  auth: inherit
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

script:post-response {
  test("Status 2xx",()=>expect(res.getStatus()).to.be.within(200,299));
}

settings {
  encodeUrl: true
  timeout: 0
}
