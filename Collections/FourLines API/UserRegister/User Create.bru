meta {
  name: User Create
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v{{apiVersion}}/UserRegister/:roleId
  body: json
  auth: none
}

params:path {
  roleId: 24367669-14ea-4a20-b362-86a246559995
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "name": "João Audibert",
    "email": "joao@email.com",
    "password": "123",
    "birthday": "2001-05-16",
    "phone": "+5554111111111",
    "registrationNumber": "026.890.330-11",
    "isActive": true
  }
}

script:post-response {
  test("Status 2xx",()=>expect(res.getStatus()).to.be.within(200,299));
}

settings {
  encodeUrl: true
  timeout: 0
}
