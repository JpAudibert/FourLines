meta {
  name: Get All Facilities
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/api/v{{apiVersion}}/owner/:ownerId/Facility
  body: none
  auth: inherit
}

params:path {
  ownerId: e1db4aa6-d725-4430-8440-62f27268ea0e
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

script:post-response {
  test("Status 2xx",()=>expect(res.getStatus()).to.be.within(200,299));
}

settings {
  encodeUrl: true
  timeout: 0
}
