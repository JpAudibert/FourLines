meta {
  name: Get Facility From Owner
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v{{apiVersion}}/owner/{{ownerId}}/Facility/:facilityId
  body: none
  auth: inherit
}

params:path {
  facilityId: e9122825-fed8-4ddd-85c0-46bbbc477417
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

script:post-response {
  test("Status 2xx",()=>expect(res.getStatus()).to.be.within(200,299));
}

settings {
  encodeUrl: true
  timeout: 0
}
